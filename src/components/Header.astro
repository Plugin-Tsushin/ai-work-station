---
import { SITE_TITLE, CATEGORIES } from '../consts';

const pathname = Astro.url.pathname;
---

<header>
	<div class="header-inner">
		<a href="/" class="logo">{SITE_TITLE}</a>
		<nav>
			<a href="/" class:list={[{ active: pathname === '/' }]}>Home</a>
			<a href="/blog" class:list={[{ active: pathname.startsWith('/blog') }]}>Blog</a>
			{Object.entries(CATEGORIES).map(([slug, cat]) => (
				<a
					href={`/category/${slug}`}
					class:list={[{ active: pathname === `/category/${slug}` || pathname === `/category/${slug}/` }]}
				>
					{cat.name}
				</a>
			))}
			<a href="/about" class:list={[{ active: pathname === '/about' || pathname === '/about/' }]}>About</a>
		</nav>
	</div>
</header>

<style>
	header {
		background: var(--white);
		border-bottom: 1px solid var(--border);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	.header-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 1rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
	}
	.logo {
		font-size: 1.2rem;
		font-weight: 800;
		color: rgb(var(--black));
		text-decoration: none;
		white-space: nowrap;
		letter-spacing: -0.02em;
	}
	.logo:hover {
		color: var(--accent);
	}
	nav {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
		scrollbar-width: none;
	}
	nav::-webkit-scrollbar {
		display: none;
	}
	nav a {
		padding: 1rem 0.6rem;
		font-size: 0.85rem;
		font-weight: 500;
		color: rgb(var(--gray));
		text-decoration: none;
		white-space: nowrap;
		border-bottom: 2px solid transparent;
		transition: all 0.2s;
	}
	nav a:hover,
	nav a.active {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}
	@media (max-width: 768px) {
		.header-inner {
			flex-direction: column;
			padding: 0.75rem 1rem 0;
			gap: 0;
		}
		nav {
			width: 100%;
		}
		nav a {
			padding: 0.6rem 0.5rem;
			font-size: 0.8rem;
		}
	}
</style>
