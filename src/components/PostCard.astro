---
import { Image } from 'astro:assets';
import FormattedDate from './FormattedDate.astro';
import CategoryBadge from './CategoryBadge.astro';
import type { CategorySlug } from '../consts';

interface Props {
	id: string;
	title: string;
	description: string;
	pubDate: Date;
	heroImage?: ImageMetadata;
	category: CategorySlug;
}

const { id, title, description, pubDate, heroImage, category } = Astro.props;
---

<article class="card">
	<a href={`/blog/${id}/`}>
		{heroImage && (
			<div class="card-image">
				<Image width={600} height={300} src={heroImage} alt={title} />
			</div>
		)}
		<div class="card-body">
			<div class="card-meta">
				<CategoryBadge category={category} />
				<span class="date"><FormattedDate date={pubDate} /></span>
			</div>
			<h3 class="card-title">{title}</h3>
			<p class="card-description">{description}</p>
		</div>
	</a>
</article>

<style>
	.card {
		background: var(--white);
		border-radius: var(--radius);
		border: 1px solid var(--border);
		overflow: hidden;
		transition: box-shadow 0.2s, transform 0.2s;
	}
	.card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}
	.card a {
		display: block;
		text-decoration: none;
		color: inherit;
	}
	.card-image img {
		width: 100%;
		height: 200px;
		object-fit: cover;
		border-radius: 0;
	}
	.card-body {
		padding: 1.25rem;
	}
	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
	}
	.date {
		font-size: 0.8rem;
		color: rgb(var(--gray));
	}
	.card-title {
		font-size: 1.05rem;
		font-weight: 700;
		line-height: 1.5;
		margin: 0 0 0.5rem 0;
		color: rgb(var(--black));
	}
	.card-description {
		font-size: 0.85rem;
		color: rgb(var(--gray));
		line-height: 1.6;
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
